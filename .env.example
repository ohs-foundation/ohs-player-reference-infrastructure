# =============================================================================
# Local development environment
#
# Copy this file to `.env` and fill in real values before running `./dev.sh up`:
#
#     cp .env.example .env
#     ${EDITOR:-vi} .env
#
# `.env` is gitignored and must never be committed.
#
# Generate strong random secrets with:
#
#     openssl rand -hex 24
#
# =============================================================================

# --- Secrets -----------------------------------------------------------------
# Postgres superuser password (used by the postgres container on first boot)
POSTGRES_ADMIN_PASSWORD=changeme

# Password for the `keycloak` database role
KEYCLOAK_DB_PASSWORD=changeme

# Bootstrap admin password for the Keycloak admin console
KEYCLOAK_ADMIN_PASSWORD=changeme

# Password for the `hapi_fhir` database role
HAPI_FHIR_DB_PASSWORD=changeme

# Client secret for the `fhir-server` Keycloak client
# Only used when HAPI_CONFIG=application-auth.yaml
HAPI_FHIR_KEYCLOAK_CLIENT_SECRET=changeme

# --- Auth mode ---------------------------------------------------------------
# Controls which HAPI FHIR config file is mounted into the container
#   application-no-auth.yaml  — HAPI FHIR runs open, no token validation
#   application-auth.yaml     — HAPI FHIR validates tokens against Keycloak
#
# Switch modes by editing this value and re-running `./dev.sh up`
HAPI_CONFIG=application-no-auth.yaml
