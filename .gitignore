charts/
*-generated.yaml

# --- Secrets & Environment ---
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.crt

# --- Terraform (if used for infra) ---
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# --- Logs & Temps ---
logs/
*.log
tmp/
.DS_Store
